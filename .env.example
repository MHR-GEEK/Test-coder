# Default hosted Ollama setup for Vercel
AI_PROVIDER=ollama
AI_BASE_URL=https://ollama.com
OLLAMA_API_KEY=replace_with_your_ollama_key
AI_MODEL=gpt-oss:120b
AI_VISION_MODEL=minimax-m3
AI_TEMPERATURE=0.35
AI_MAX_TOKENS=4096

# Local Ollama does not need an API key:
# AI_PROVIDER=ollama
# AI_BASE_URL=http://127.0.0.1:11434
# AI_MODEL=llama3.1

# OpenAI:
# AI_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_openai_key
# AI_MODEL=gpt-4.1-mini

# OpenRouter:
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=replace_with_your_openrouter_key
# AI_MODEL=openai/gpt-4.1-mini

# Groq:
# AI_PROVIDER=groq
# GROQ_API_KEY=replace_with_your_groq_key
# AI_MODEL=llama-3.3-70b-versatile

# Together AI:
# AI_PROVIDER=together
# TOGETHER_API_KEY=replace_with_your_together_key
# AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Generic OpenAI-compatible provider:
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://your-provider.example/v1
# AI_API_KEY=replace_with_provider_key
# AI_MODEL=your-model-name
